# HELP

# DEV TOOLING

format:
	@echo "  FMT     Formatting *.c *.h ..."
	@find . \( -name "*.c" -o -name "*.h" \) \
		-not -path "./setup/*" -not -path "./build/*" -not -path "./.git/*" \
		| xargs clang-format -i
	@echo "✓ Format done"

# Análisis estático con cppcheck (opcional).
analyze:
	@if command -v cppcheck >/dev/null 2>&1; then \
		echo "  CPPCHECK --enable=warning,style --quiet ..."; \
		cppcheck --enable=warning,style --quiet -i.git -iiso -iiso_test .; \
	else \
		echo "cppcheck is not installed; skipping static analysis."; \
		echo "Install cppcheck to enable this target (e.g. apt install cppcheck, dnf install cppcheck, pacman -S cppcheck, brew install cppcheck)."; \
	fi

compile-commands:
	@echo "  CC_JSON Generating compile_commands.json ..."
	@echo "[" > compile_commands.json
	@first=true; count=0; \
	for src in $(patsubst %.o,%.c,$(filter %.o,$(ALL_OBJS))); do \
		if [ -f "$$src" ]; then \
			if [ "$$first" = true ]; then first=false; else echo "," >> compile_commands.json; fi; \
			printf '  { "directory": "%s", "file": "%s", "command": "%s %s -c %s" }' \
				"$(CURDIR)" "$$src" "$(CC)" "$(CFLAGS)" "$$src" >> compile_commands.json; \
			count=$$((count + 1)); \
		fi; \
	done; \
	for src in $(patsubst %.o,%.cpp,$(filter %.o,$(ALL_OBJS))); do \
		if [ -f "$$src" ]; then \
			if [ "$$first" = true ]; then first=false; else echo "," >> compile_commands.json; fi; \
			printf '  { "directory": "%s", "file": "%s", "command": "%s %s -c %s" }' \
				"$(CURDIR)" "$$src" "g++" "$(CXXFLAGS_COMPILE)" "$$src" >> compile_commands.json; \
			count=$$((count + 1)); \
		fi; \
	done; \
	echo "" >> compile_commands.json; \
	echo "]" >> compile_commands.json; \
	echo "✓ compile_commands.json generated ($$count entries)"

disasm: kernel-x64.bin
	@echo "  OBJDUMP kernel-x64.disasm ..."
	@objdump -d -S kernel-x64.bin > kernel-x64.disasm
	@echo "✓ Disassembly: kernel-x64.disasm ($(shell wc -l < kernel-x64.disasm 2>/dev/null || echo ?) lines)"

stack-usage:
	@echo "  STACK   Rebuilding with -fstack-usage ..."
	@$(MAKE) clean
	@$(MAKE) CFLAGS="$(CFLAGS) -fstack-usage" kernel-x64.bin
	@echo ""
	@echo "Top 30 stack consumers:"
	@echo "-----------------------------------------------"
	@find . -name "*.su" -exec cat {} + 2>/dev/null | sort -t: -k3 -rn | head -30
	@echo ""

