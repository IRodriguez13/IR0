# FASE58L — BusyBox ash + extended Unix applets (MINIX-style userspace).
# Base: fase58_busybox.config + inspection/process/terminal/util applets.
#
# Still OFF: networking, login/getty, vi, job control, runit, init replacement.
#
# Part B — shell UX (line editing / tab / history):
#   Keep CONFIG_FEATURE_EDITING=n until kernel TTY raw/edit path is validated.
#   TTY audit (kernel console.c): Backspace/DEL OK; TIOCGWINSZ 80x25 OK;
#   Ctrl+C and ESC [ arrow sequences not safe in canon mode yet.
#
# Known kernel gaps (applets may fail or be degraded):
#   ps       — needs /proc listing + per-pid stat (best-effort)
#   dmesg    — needs kernel log ring (may ENOSYS / empty)
#   find     — needs recursive directory walk (same as ls)
#   chown    — partial VFS credential support
#   stty     — TCGETS/TCSETS/TIOCGWINSZ only (subset of Linux stty)

CONFIG_BUSYBOX=y
CONFIG_STATIC=y

# Core shell
CONFIG_ASH=y
CONFIG_SH_IS_ASH=y
CONFIG_SH_IS_NONE=n
CONFIG_FEATURE_SH_STANDALONE=y
CONFIG_BASH_IS_NONE=y
CONFIG_ASH_JOB_CONTROL=n
CONFIG_FEATURE_EDITING=n
CONFIG_FEATURE_TAB_COMPLETION=n
CONFIG_FEATURE_EDITING_HISTORY=n

# Coreutils — file / directory
CONFIG_CAT=y
CONFIG_ECHO=y
CONFIG_PWD=y
CONFIG_LS=y
CONFIG_MKDIR=y
CONFIG_RMDIR=y
CONFIG_RM=y
CONFIG_CP=y
CONFIG_MV=y
CONFIG_TOUCH=y
CONFIG_LN=y
CONFIG_READLINK=y
CONFIG_STAT=y
CONFIG_CHMOD=y
CONFIG_CHOWN=y
CONFIG_BASENAME=y
CONFIG_DIRNAME=y

# Coreutils — text / filters
CONFIG_GREP=y
CONFIG_HEAD=y
CONFIG_TAIL=y
CONFIG_WC=y
CONFIG_SORT=y
CONFIG_UNIQ=y

# Coreutils — misc
CONFIG_TEST=y
CONFIG_TRUE=y
CONFIG_FALSE=y
CONFIG_UNAME=y
CONFIG_CLEAR=y
CONFIG_SLEEP=y
CONFIG_PRINTF=y
CONFIG_ENV=y

# Inspection
CONFIG_FIND=y
CONFIG_DMESG=y

# Processes
CONFIG_PS=y
CONFIG_KILL=y

# Terminal
CONFIG_STTY=y
CONFIG_RESET=y

# Utilities
CONFIG_WHICH=y

# Keep off
CONFIG_AWK=n
CONFIG_SED=n
CONFIG_VI=n
CONFIG_NC=n
CONFIG_TELNETD=n
CONFIG_HTTPD=n
CONFIG_IFCONFIG=n
CONFIG_PING=n
CONFIG_ROUTE=n
CONFIG_UDHCPC=n
CONFIG_INIT=n
CONFIG_RUNSV=n
CONFIG_SV=n
