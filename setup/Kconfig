#
# IR0 Kernel Configuration
#
# This file defines every user-visible configuration symbol.
# Only subsystems that can actually be compiled out are toggleable;
# core subsystems (memory, scheduler, VFS, interrupts) are always built.
#

menu "General"

    config KERNEL_DEBUG_SHELL
        bool "Use debug shell as init (PID 1)"
        default y
        help
          When enabled the kernel boots into the built-in debug shell
          instead of loading /sbin/init from the filesystem.
          Disable this only when you have a working userspace init.

    config TICK_RATE_HZ
        int "Timer tick rate (Hz)"
        range 100 1000
        default 1000
        help
          Frequency of the PIT timer interrupt. Higher values give finer
          scheduling granularity at the cost of more IRQ overhead.

    config ENABLE_EXAMPLE_DRIVERS
        bool "Enable example external drivers (C++/Rust)"
        default n
        help
          Build and register optional sample drivers used for multi-language
          integration testing. Keep disabled for production-like builds.

endmenu

menu "Networking"

    config ENABLE_NETWORKING
        bool "IPv4 network stack (ARP, IP, ICMP, UDP, DNS)"
        default y
        help
          Compile the full network stack (net/) and the RTL8139 NIC driver.
          Disabling this removes all networking support from the kernel.

endmenu

menu "Sound"

    config ENABLE_SOUND
        bool "Sound subsystem (Sound Blaster 16 + Adlib OPL2)"
        default y
        help
          Compile the Sound Blaster 16 and Adlib OPL2 audio drivers
          plus the ISA DMA helper used by SB16.

endmenu

menu "Bluetooth"

    config ENABLE_BLUETOOTH
        bool "Bluetooth HCI over UART"
        default y
        help
          Compile the Bluetooth HCI-UART transport, device manager,
          and sysfs/procfs integration.

endmenu

menu "Input"

    config ENABLE_MOUSE
        bool "PS/2 mouse driver"
        default y
        help
          Compile the PS/2 mouse driver. The PS/2 keyboard is always built.

endmenu

menu "Graphics"

    config ENABLE_VBE
        bool "VBE framebuffer support"
        default y
        help
          Use the VESA BIOS Extensions framebuffer when available
          (via Multiboot). VGA text-mode console is always compiled.

endmenu

menu "Tooling"

    config TOOL_AUTO_RUN_DEPTEST
        bool "Run deptest automatically before 'make ir0'"
        default n
        help
          When enabled, 'make ir0' executes dependency checks first.
          Useful for new contributors or CI-like local flows.

    config TOOL_DEFAULT_DISK_FS
        int "Default filesystem for create-disk (0=minix,1=fat32,2=ext4)"
        range 0 2
        default 0
        help
          Select which filesystem create-disk uses when no arguments
          are passed to the make target.

    config TOOL_DEFAULT_DISK_SIZE_MB
        int "Default disk size for create-disk (MB)"
        range 64 8192
        default 200
        help
          Disk size used by create-disk when no explicit size is passed.

    config TOOL_UNIBUILD_DEFAULT_FILES
        string "Default files for unibuild targets (space-separated)"
        help
          Optional default files used by unibuild targets when no positional
          file arguments are provided. Example: fs/vfs.c fs/path.c

    config TOOL_UNIBUILD_EXCLUDE_FILE
        string "Exclude one file from unibuild target file list"
        help
          If set, this exact file path is removed from unibuild target input
          before invoking scripts/unibuild.sh.

endmenu

menu "Debugging"

    config DEBUG_MEMORY_ALLOCATOR
        bool "Heap allocator debug output"
        default n

    config DEBUG_PMM
        bool "Physical memory manager debug output"
        default n

    config DEBUG_MEMORY_COALESCING
        bool "Allocator coalescing debug output"
        default n

    config DEBUG_MEMORY_STATS
        bool "Allocator statistics debug output"
        default n

    config DEBUG_PAGING
        bool "Paging operations debug output"
        default n

    config DEBUG_PAGE_FAULTS
        bool "Page fault handler debug output"
        default n

    config DEBUG_PROCESS
        bool "Process creation/destruction debug"
        default n

    config DEBUG_SCHEDULER
        bool "Scheduler debug output"
        default n

    config DEBUG_FORK
        bool "Fork path debug output"
        default n

    config DEBUG_VFS
        bool "VFS operations debug output"
        default n

    config DEBUG_FS_MOUNT
        bool "Filesystem mount/unmount debug output"
        default n

    config DEBUG_SYSCALLS
        bool "Syscall invocations debug output"
        default n

    config DEBUG_SYSCALL_PARAMS
        bool "Detailed syscall parameter debug output"
        default n

    config DEBUG_KEYBOARD
        bool "Keyboard/stdin read debug output"
        default n

endmenu
