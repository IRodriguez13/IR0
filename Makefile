unibuild-clean:
	@if [ -z "$(FILE)" ]; then \
		echo "Error: FILE parameter required"; \
		echo "Usage: make unibuild-clean <source_file>"; \
		echo "Example: make unibuild-clean fs/tmpfs.c"; \
		exit 1; \
	fi
