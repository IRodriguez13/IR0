# FASE58 — unified BusyBox ash + coreutils (default interactive build).
# Merges fase50_minimal + extended safe applets.
# Still off: job control, line editing, vi, networking, heavy /proc deps.

CONFIG_BUSYBOX=y
CONFIG_STATIC=y

# Core shell
CONFIG_ASH=y
CONFIG_SH_IS_ASH=y
CONFIG_SH_IS_NONE=n
CONFIG_FEATURE_SH_STANDALONE=y
CONFIG_BASH_IS_NONE=y
CONFIG_ASH_JOB_CONTROL=n
CONFIG_FEATURE_EDITING=n

# Coreutils — file / directory
CONFIG_CAT=y
CONFIG_ECHO=y
CONFIG_PWD=y
CONFIG_LS=y
CONFIG_MKDIR=y
CONFIG_RMDIR=y
CONFIG_RM=y
CONFIG_CP=y
CONFIG_MV=y
CONFIG_TOUCH=y
CONFIG_LN=y
CONFIG_READLINK=y
CONFIG_STAT=y
CONFIG_BASENAME=y
CONFIG_DIRNAME=y

# Coreutils — text / filters (from fase50)
CONFIG_GREP=y
CONFIG_HEAD=y
CONFIG_TAIL=y
CONFIG_WC=y

# Coreutils — misc
CONFIG_TEST=y
CONFIG_TRUE=y
CONFIG_FALSE=y
CONFIG_UNAME=y
CONFIG_CLEAR=y
CONFIG_SLEEP=y
CONFIG_PRINTF=y

# Proc / system (best-effort; depends on kernel /proc)
CONFIG_PS=y
CONFIG_KILL=y
CONFIG_DMESG=y

# Keep off for now
CONFIG_AWK=n
CONFIG_SED=n
CONFIG_VI=n
